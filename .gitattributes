# テキストファイルは改行を正規化し、作業ツリーも LF に統一する
# （Windows でも Vite / Biome / pnpm は LF で問題なく動作する）
* text=auto eol=lf

# Windows 専用スクリプトのみ CRLF
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# バイナリ（改行変換・diff 対象外）
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.woff binary
*.woff2 binary
*.mp3 binary
*.ogg binary
*.glb binary
*.gltf binary

# ロックファイルは自動生成物として扱う（GitHub の diff で折りたたむ）
pnpm-lock.yaml linguist-generated
